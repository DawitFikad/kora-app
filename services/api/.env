
# ----------------------------------------
# 🔹 CORE DATABASE & SECURITY
# ----------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/et_ticket?schema=public"
JWT_SECRET="super-secret-key-change-this-in-prod"
REDIS_URL="redis://localhost:6379"

# ----------------------------------------
# 🔹 TELEBIRR CREDENTIALS (B2B & C2B)
# ----------------------------------------
TELEBIRR_MERCHANT_APP_ID="your_merchant_app_id"
TELEBIRR_FABRIC_APP_ID="your_fabric_app_id"
TELEBIRR_SHORT_CODE="your_short_code"
TELEBIRR_APP_SECRET="your_app_secret"
TELEBIRR_PRIVATE_KEY="your_private_key"

# ----------------------------------------
# 🔹 OTHER PAYMENT PROVIDERS (Using same key setup)
# ----------------------------------------
CBE_BIRR_API_KEY="cbe-mock-key"
AMOLE_API_KEY="amole-mock-key"
CHAPA_SECRET_KEY="CHASECK_TEST-xxxxxxxxxxxxxxxx"

# ----------------------------------------
# 🔹 NOTIFICATION KEYS
# ----------------------------------------
SMS_PROVIDER_API_KEY="mock-sms-key"
SENDGRID_API_KEY="mock-sendgrid-key"

# ----------------------------------------
# 🔹 LOGGING
# ----------------------------------------
LOG_LEVEL="info"
