generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  phoneNumber         String               @unique
  email               String?              @unique
  password            String?
  role                Role                 @default(USER)
  status              AccountStatus        @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  disputes            Dispute[]
  fraudAlerts         FraudAlert[]
  notifications       NotificationLog[]
  organizer           OrganizerProfile?
  purchases           Purchase[]
  refreshTokens       RefreshToken[]
  savedPaymentMethods SavedPaymentMethod[]
  tickets             Ticket[]
  profile             UserProfile?
}

model SavedPaymentMethod {
  id            Int      @id @default(autoincrement())
  userId        Int
  provider      String
  accountNumber String
  accountName   String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  fullName  String?
  avatarUrl String?
  bio       String?
  gender    String?
  birthDate DateTime?
  language  String    @default("en")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizerProfile {
  id               Int               @id @default(autoincrement())
  userId           Int               @unique
  organizationName String
  description      String?
  contactPhone     String
  contactEmail     String?
  city             String
  payoutDetails    String
  status           OrganizerStatus   @default(PENDING)
  adminNote        String?
  logoUrl          String?
  emailVerified    Boolean           @default(false)
  feeType          String?
  feeFixed         Decimal?          @db.Decimal(10, 2)
  feePercentage    Decimal?          @db.Decimal(10, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  events           Event[]
  fraudAlerts      FraudAlert[]
  notifications    NotificationLog[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet           OrganizerWallet?
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model City {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model Event {
  id            Int                    @id @default(autoincrement())
  title         String
  titleAm       String?
  description   String?
  descriptionAm String?
  venue         String
  dateTime      DateTime
  status        EventStatus            @default(PENDING)
  eventType     EventType              @default(CAPACITY)
  totalCapacity Int?
  coverImage    String?
  gallery       String[]               @default([])
  featured      Boolean                @default(false)
  feeType       String?
  feeFixed      Decimal?               @db.Decimal(10, 2)
  feePercentage Decimal?               @db.Decimal(10, 2)
  organizerId   Int
  categoryId    Int
  cityId        Int
  refundPolicy     String                 @default("No refunds within 24 hours of event.")
  minAge           Int                    @default(0)
  additionalPolicy String?
  hasSeatMap       Boolean                @default(false)
  seatMapConfig    String?
  createdAt        DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  entryMetrics  EntryMetric[]
  category      Category               @relation(fields: [categoryId], references: [id])
  city          City                   @relation(fields: [cityId], references: [id])
  organizer     OrganizerProfile       @relation(fields: [organizerId], references: [id])
  transactions  FinancialTransaction[]
  fraudAlerts   FraudAlert[]
  promoCodes    PromoCode[]
  tickets       Ticket[]
  tiers         TicketTier[]
}

model PromoCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  discount  Decimal   @db.Decimal(10, 2)
  type      String    @default("PERCENTAGE")
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  eventId   Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model TicketTier {
  id            Int          @id @default(autoincrement())
  name          String
  price         Decimal      @db.Decimal(10, 2)
  capacity      Int
  salesStart    DateTime?
  salesEnd      DateTime?
  maxPerUser    Int          @default(5)
  eventId       Int
  tickets       Ticket[]
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Ticket {
  id             String       @id @default(uuid())
  qrPayload      String       @unique
  status         TicketStatus @default(VALID)
  basePrice      Decimal?     @db.Decimal(10, 2)
  commissionRate Decimal?     @db.Decimal(10, 2)
  commissionAmt  Decimal?     @db.Decimal(10, 2)
  convenienceFee Decimal?     @default(0.0) @db.Decimal(10, 2)
  organizerNet   Decimal?     @db.Decimal(10, 2)
  platformNet    Decimal?     @db.Decimal(10, 2)
  userId         Int
  eventId        Int
  tierId         Int
  seatNumber     String?
  purchaseId     Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  fraudAlerts    FraudAlert[]
  event          Event        @relation(fields: [eventId], references: [id])
  purchase       Purchase?    @relation(fields: [purchaseId], references: [id])
  tier           TicketTier   @relation(fields: [tierId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model Purchase {
  id            Int                    @id @default(autoincrement())
  status        PaymentStatus          @default(PENDING)
  totalAmount   Decimal                @db.Decimal(10, 2)
  paymentRef    String                 @unique
  externalRef   String?                @unique
  paymentMethod String
  failureReason String?
  userId        Int
  metadata      Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  disputes      Dispute[]
  transactions  FinancialTransaction[]
  user          User                   @relation(fields: [userId], references: [id])
  refunds       Refund[]
  tickets       Ticket[]
}

model OrganizerWallet {
  id               Int              @id @default(autoincrement())
  organizerId      Int              @unique
  pendingBalance   Decimal          @default(0.0) @db.Decimal(12, 2)
  availableBalance Decimal          @default(0.0) @db.Decimal(12, 2)
  totalWithdrawn   Decimal          @default(0.0) @db.Decimal(12, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organizer        OrganizerProfile @relation(fields: [organizerId], references: [id])
  payouts          PayoutBatch[]
  ledgerEntries    WalletLedger[]
}

model WalletLedger {
  id            Int             @id @default(autoincrement())
  walletId      Int
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  description   String?
  referenceId   String
  balanceBefore Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())
  wallet        OrganizerWallet @relation(fields: [walletId], references: [id])
}

model FinancialTransaction {
  id            Int             @id @default(autoincrement())
  status        FinancialStatus @default(INITIATED)
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  feeAmount     Decimal         @default(0.0) @db.Decimal(10, 2)
  netAmount     Decimal         @db.Decimal(10, 2)
  purchaseId    Int?
  eventId       Int?
  payoutBatchId Int?
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  event         Event?          @relation(fields: [eventId], references: [id])
  payoutBatch   PayoutBatch?    @relation(fields: [payoutBatchId], references: [id])
  purchase      Purchase?       @relation(fields: [purchaseId], references: [id])
  refund        Refund?
}

model PayoutBatch {
  id            Int                    @id @default(autoincrement())
  status        FinancialStatus        @default(INITIATED)
  amount        Decimal                @db.Decimal(12, 2)
  method        PayoutMethod
  payoutDetails String
  walletId      Int
  processedAt   DateTime?
  adminId       Int?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  transactions  FinancialTransaction[]
  wallet        OrganizerWallet        @relation(fields: [walletId], references: [id])
}

model PlatformFeeConfig {
  id            Int      @id @default(autoincrement())
  name          String
  feeType       String   @default("PERCENTAGE")
  feeFixed      Decimal  @default(0.0) @db.Decimal(10, 2)
  feePercentage Decimal  @default(0.0) @db.Decimal(10, 2)
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model ScanLog {
  id         Int       @id @default(autoincrement())
  ticketId   String
  eventId    Int
  gateId     String?
  deviceId   String?
  mode       String
  status     String
  reason     String?
  timestamp  DateTime  @default(now())
  deviceTime DateTime?
  metadata   Json?
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FraudAlert {
  id          Int               @id @default(autoincrement())
  type        FraudType
  riskLevel   RiskLevel
  message     String
  isCleared   Boolean           @default(false)
  resolvedAt  DateTime?
  adminNote   String?
  userId      Int?
  eventId     Int?
  organizerId Int?
  ticketId    String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  event       Event?            @relation(fields: [eventId], references: [id])
  organizer   OrganizerProfile? @relation(fields: [organizerId], references: [id])
  ticket      Ticket?           @relation(fields: [ticketId], references: [id])
  user        User?             @relation(fields: [userId], references: [id])
}

model RiskScore {
  id          Int       @id @default(autoincrement())
  entityType  String
  entityId    String
  score       Int       @default(0)
  level       RiskLevel @default(LOW)
  lastUpdated DateTime  @default(now())
  metadata    Json?
}

model EntryMetric {
  id          Int      @id @default(autoincrement())
  eventId     Int
  gateId      String?
  entryCount  Int      @default(0)
  failedCount Int      @default(0)
  timestamp   DateTime
  event       Event    @relation(fields: [eventId], references: [id])

  @@unique([eventId, gateId, timestamp])
}

model Refund {
  id            Int                   @id @default(autoincrement())
  status        RefundStatus          @default(PENDING)
  amount        Decimal               @db.Decimal(10, 2)
  reason        RefundReason          @default(OTHER)
  description   String?
  purchaseId    Int
  transactionId Int?                  @unique
  processedBy   Int?
  failureReason String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  disputes      Dispute[]
  purchase      Purchase              @relation(fields: [purchaseId], references: [id])
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id])
}

model Dispute {
  id         Int           @id @default(autoincrement())
  status     DisputeStatus @default(OPEN)
  source     DisputeSource
  reason     String
  purchaseId Int?
  refundId   Int?
  userId     Int
  metadata   Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  purchase   Purchase?     @relation(fields: [purchaseId], references: [id])
  refund     Refund?       @relation(fields: [refundId], references: [id])
  user       User          @relation(fields: [userId], references: [id])
}

model NotificationLog {
  id          Int                 @id @default(autoincrement())
  userId      Int?
  organizerId Int?
  channel     NotificationChannel
  recipient   String
  title       String?
  content     String
  status      String
  isRead      Boolean             @default(false)
  providerRef String?
  metadata    Json?
  createdAt   DateTime            @default(now())
  organizer   OrganizerProfile?   @relation(fields: [organizerId], references: [id])
  user        User?               @relation(fields: [userId], references: [id])
}

model HomepageBanner {
  id          Int       @id @default(autoincrement())
  title       String?
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  clickCount  Int       @default(0)
  ctaText     String?   @default("Learn More")
  endDate     DateTime?
  priority    Int       @default(0)
  startDate   DateTime?
  targetRules Json?
  viewCount   Int       @default(0)
}

enum Role {
  USER
  ORGANIZER
  ADMIN
  SCANNER
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OrganizerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum EventType {
  CAPACITY
  SEAT_MAP
}

enum TicketStatus {
  GENERATED
  SOLD
  VALID
  USED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum FinancialStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  SETTLED
  RELEASED
  PAID_OUT
  FAILED
  REFUNDED
  DISPUTED
}

enum TransactionType {
  TICKET_PURCHASE
  PLATFORM_FEE
  ORGANIZER_PAYOUT
  REFUND
  ADJUSTMENT
}

enum PayoutMethod {
  BANK_TRANSFER
  MOBILE_MONEY
  MANUAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudType {
  REPLAY
  OFFLINE_ABUSE
  BOT_PURCHASE
  INSIDER_ABUSE
  PAYMENT_FRAUD
  IP_ANOMALY
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum RefundReason {
  CANCELLATION
  DUPLICATE_PAYMENT
  POSTPONEMENT
  ORGANIZER_APPROVED
  ADMIN_FORCE
  OTHER
}

enum DisputeSource {
  USER_COMPLAINT
  ORGANIZER_CHALLENGE
  BANK_CHARGEBACK
}

enum NotificationChannel {
  SMS
  PUSH
  EMAIL
}
