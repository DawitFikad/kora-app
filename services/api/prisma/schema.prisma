generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ORGANIZER
  ADMIN
  SCANNER
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OrganizerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum EventType {
  CAPACITY
  SEAT_MAP
}

enum TicketStatus {
  GENERATED
  SOLD
  VALID
  USED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum FinancialStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  SETTLED
  RELEASED
  PAID_OUT
  FAILED
  REFUNDED
  DISPUTED
}

enum TransactionType {
  TICKET_PURCHASE
  PLATFORM_FEE
  ORGANIZER_PAYOUT
  REFUND
  ADJUSTMENT
}

enum PayoutMethod {
  BANK_TRANSFER
  MOBILE_MONEY
  MANUAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudType {
  REPLAY
  OFFLINE_ABUSE
  BOT_PURCHASE
  INSIDER_ABUSE
  PAYMENT_FRAUD
  IP_ANOMALY
}

model User {
  id          Int           @id @default(autoincrement())
  phoneNumber String        @unique
  email       String?       @unique
  password    String?
  role        Role          @default(USER)
  status      AccountStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  profile               UserProfile?
  organizer             OrganizerProfile?
  refreshTokens         RefreshToken[]
  tickets               Ticket[]
  purchases             Purchase[]
  fraudAlerts           FraudAlert[]
  disputes              Dispute[]
  notifications         NotificationLog[]
  savedPaymentMethods   SavedPaymentMethod[]
}

model SavedPaymentMethod {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   // "TELEBIRR", "CBE_BIRR", "CHAPA", "BANK"
  accountNumber String   // e.g., phone number or masked card
  accountName   String?  // Optional name for the account
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UserProfile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String?
  avatarUrl String?
  bio       String?
  gender    String?
  birthDate DateTime?
  language  String    @default("en") // "am" for Amharic, "en" for English
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model OrganizerProfile {
  id               Int             @id @default(autoincrement())
  userId           Int             @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationName String
  contactPhone     String
  contactEmail     String?
  city             String
  payoutDetails    String // Bank or mobile money details
  status           OrganizerStatus @default(PENDING)
  adminNote        String?
  logoUrl          String?  // Profile picture/logo URL
  emailVerified    Boolean  @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  events        Event[]
  wallet        OrganizerWallet?
  notifications NotificationLog[]
  fraudAlerts   FraudAlert[]
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model City {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model Event {
  id            Int         @id @default(autoincrement())
  title         String
  description   String?
  venue         String
  dateTime      DateTime
  status        EventStatus @default(PENDING)
  eventType     EventType   @default(CAPACITY)
  totalCapacity Int? // Used for CAPACITY type

  coverImage String?
  gallery    String[] @default([])
  featured   Boolean  @default(false)

  // Commission settings for this specific event
  feeType       String  @default("PERCENTAGE") // PERCENTAGE, FIXED, HYBRID
  feeFixed      Decimal @default(0.0) @db.Decimal(10, 2)
  feePercentage Decimal @default(0.0) @db.Decimal(10, 2)

  organizerId Int
  organizer   OrganizerProfile @relation(fields: [organizerId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  cityId Int
  city   City @relation(fields: [cityId], references: [id])

  tiers        TicketTier[]
  tickets      Ticket[]
  transactions FinancialTransaction[]
  fraudAlerts  FraudAlert[]
  entryMetrics EntryMetric[]
  promoCodes   PromoCode[]
  
  refundPolicy String @default("No refunds within 24 hours of event.")
  
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model PromoCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  discount  Decimal  @db.Decimal(10, 2)
  type      String   @default("PERCENTAGE") // PERCENTAGE, FIXED
  expiresAt DateTime?
  maxUses   Int?
  usedCount Int      @default(0)
  isActive  Boolean  @default(true)

  eventId Int
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketTier {
  id       Int      @id @default(autoincrement())
  name     String // Regular, VIP, etc.
  price    Decimal  @db.Decimal(10, 2)
  capacity Int
  eventId  Int
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets  Ticket[]
}

model Ticket {
  id        String       @id @default(uuid())
  qrPayload String       @unique
  status    TicketStatus @default(VALID)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  tierId Int
  tier   TicketTier @relation(fields: [tierId], references: [id])

  seatNumber String? // For SEAT_MAP events

  purchaseId  Int?
  purchase    Purchase?    @relation(fields: [purchaseId], references: [id])
  fraudAlerts FraudAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id            Int           @id @default(autoincrement())
  status        PaymentStatus @default(PENDING)
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentRef    String        @unique // Our internal unique ref
  externalRef   String?       @unique // Provider's ref (Chapa, TeleBirr, etc)
  paymentMethod String // e.g., "CHAPA", "TELEBIRR", "CBE_BIRR", "AMOLE"
  failureReason String?

  userId Int
  user   User @relation(fields: [userId], references: [id])

  metadata Json? // To store eventId, tierId, quantity, seatNumbers

  tickets      Ticket[]
  transactions FinancialTransaction[]
  refunds      Refund[]
  disputes     Dispute[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model OrganizerWallet {
  id          Int              @id @default(autoincrement())
  organizerId Int              @unique
  organizer   OrganizerProfile @relation(fields: [organizerId], references: [id])

  pendingBalance   Decimal @default(0.0) @db.Decimal(12, 2)
  availableBalance Decimal @default(0.0) @db.Decimal(12, 2)
  totalWithdrawn   Decimal @default(0.0) @db.Decimal(12, 2)

  ledgerEntries WalletLedger[]
  payouts       PayoutBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletLedger {
  id       Int             @id @default(autoincrement())
  walletId Int
  wallet   OrganizerWallet @relation(fields: [walletId], references: [id])

  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?
  referenceId String // ID of related entity (Purchase, PayoutBatch, etc)

  balanceBefore Decimal @db.Decimal(12, 2)
  balanceAfter  Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
}

model FinancialTransaction {
  id     Int             @id @default(autoincrement())
  status FinancialStatus @default(INITIATED)
  type   TransactionType

  amount    Decimal @db.Decimal(10, 2)
  feeAmount Decimal @default(0.0) @db.Decimal(10, 2)
  netAmount Decimal @db.Decimal(10, 2) // amount - feeAmount

  purchaseId Int?
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])

  eventId Int?
  event   Event? @relation(fields: [eventId], references: [id])

  payoutBatchId Int?
  payoutBatch   PayoutBatch? @relation(fields: [payoutBatchId], references: [id])

  refund   Refund?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PayoutBatch {
  id     Int             @id @default(autoincrement())
  status FinancialStatus @default(INITIATED)

  amount        Decimal      @db.Decimal(12, 2)
  method        PayoutMethod
  payoutDetails String // Bank/Mobile details used for this payout

  walletId Int
  wallet   OrganizerWallet @relation(fields: [walletId], references: [id])

  transactions FinancialTransaction[]

  processedAt DateTime?
  adminId     Int? // The admin who approved/processed it

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformFeeConfig {
  id            Int     @id @default(autoincrement())
  name          String // e.g., "Default Global Fee"
  feeType       String  @default("PERCENTAGE") // PERCENTAGE, FIXED, HYBRID
  feeFixed      Decimal @default(0.0) @db.Decimal(10, 2)
  feePercentage Decimal @default(0.0) @db.Decimal(10, 2)
  isDefault     Boolean @default(false)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScanLog {
  id         Int       @id @default(autoincrement())
  ticketId   String
  eventId    Int
  gateId     String?
  deviceId   String?
  mode       String // "ONLINE" | "OFFLINE"
  status     String // "SUCCESS" | "REJECTED"
  reason     String?
  timestamp  DateTime  @default(now())
  deviceTime DateTime? // Original time from device for offline sync

  metadata Json? // Any extra context (e.g. error details)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FraudAlert {
  id        Int       @id @default(autoincrement())
  type      FraudType
  riskLevel RiskLevel
  message   String

  // Investigation status
  isCleared  Boolean   @default(false)
  resolvedAt DateTime?
  adminNote  String?

  // Associations (nullable as alerts can be for various entities)
  userId      Int?
  user        User?             @relation(fields: [userId], references: [id])
  eventId     Int?
  event       Event?            @relation(fields: [eventId], references: [id])
  organizerId Int?
  organizer   OrganizerProfile? @relation(fields: [organizerId], references: [id])
  ticketId    String?
  ticket      Ticket?           @relation(fields: [ticketId], references: [id])

  // Context metadata
  metadata Json? // IPs, device IDs, timestamps involved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiskScore {
  id         Int       @id @default(autoincrement())
  entityType String // "USER", "ORGANIZER", "DEVICE"
  entityId   String // ID as string to support device IDs
  score      Int       @default(0) // 0-100
  level      RiskLevel @default(LOW)

  lastUpdated DateTime @default(now())
  metadata    Json? // History of adjustments
}

model EntryMetric {
  id      Int   @id @default(autoincrement())
  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  gateId      String?
  entryCount  Int     @default(0)
  failedCount Int     @default(0)

  // Hourly or per-minute buckets
  timestamp DateTime // Bucket start time

  @@unique([eventId, gateId, timestamp])
}

model Refund {
  id          Int          @id @default(autoincrement())
  status      RefundStatus @default(PENDING)
  amount      Decimal      @db.Decimal(10, 2)
  reason      RefundReason @default(OTHER)
  description String?

  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  transactionId Int?                  @unique
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id])

  processedBy   Int? // Admin user ID
  failureReason String?

  disputes Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dispute {
  id     Int           @id @default(autoincrement())
  status DisputeStatus @default(OPEN)
  source DisputeSource
  reason String

  purchaseId Int?
  purchase   Purchase? @relation(fields: [purchaseId], references: [id])

  refundId Int?
  refund   Refund? @relation(fields: [refundId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  metadata Json? // Evidence, communication history

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id     Int   @id @default(autoincrement())
  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  organizerId Int?
  organizer   OrganizerProfile? @relation(fields: [organizerId], references: [id])

  channel   NotificationChannel
  recipient String // Phone number or Email
  title     String?
  content   String

  status      String // "SENT", "FAILED", "DELIVERED"
  isRead      Boolean @default(false)
  providerRef String? // External message ID

  metadata Json? // Event identifiers, error logs

  createdAt DateTime @default(now())
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum RefundReason {
  CANCELLATION
  DUPLICATE_PAYMENT
  POSTPONEMENT
  ORGANIZER_APPROVED
  ADMIN_FORCE
  OTHER
}

enum DisputeSource {
  USER_COMPLAINT
  ORGANIZER_CHALLENGE
  BANK_CHARGEBACK
}

enum NotificationChannel {
  SMS
  PUSH
  EMAIL
}
