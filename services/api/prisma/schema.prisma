generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ORGANIZER
  ADMIN
  SCANNER
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OrganizerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum EventType {
  CAPACITY
  SEAT_MAP
}

enum TicketStatus {
  GENERATED
  SOLD
  VALID
  USED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum FinancialStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  SETTLED
  RELEASED
  PAID_OUT
  FAILED
  REFUNDED
  DISPUTED
}

enum TransactionType {
  TICKET_PURCHASE
  PLATFORM_FEE
  ORGANIZER_PAYOUT
  REFUND
  ADJUSTMENT
}

enum PayoutMethod {
  BANK_TRANSFER
  MOBILE_MONEY
  MANUAL
}

model User {
  id            Int            @id @default(autoincrement())
  phoneNumber   String         @unique
  email         String?        @unique
  password      String?
  role          Role           @default(USER)
  status        AccountStatus  @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile       UserProfile?
  organizer     OrganizerProfile?
  refreshTokens RefreshToken[]
  tickets       Ticket[]
  purchases     Purchase[]
}

model UserProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String?
  language  String   @default("en") // "am" for Amharic, "en" for English
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizerProfile {
  id               Int             @id @default(autoincrement())
  userId           Int             @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationName String
  contactPhone     String
  contactEmail     String?
  city             String
  payoutDetails    String // Bank or mobile money details
  status           OrganizerStatus @default(PENDING)
  adminNote        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  events           Event[]
  wallet           OrganizerWallet?
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model City {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model Event {
  id               Int           @id @default(autoincrement())
  title            String
  description      String?
  venue            String
  dateTime         DateTime
  status           EventStatus   @default(PENDING)
  eventType        EventType     @default(CAPACITY)
  totalCapacity    Int?          // Used for CAPACITY type
  
  coverImage       String?
  gallery          String[]      @default([])
  featured         Boolean       @default(false)
  
  // Commission settings for this specific event
  feeType          String        @default("PERCENTAGE") // PERCENTAGE, FIXED, HYBRID
  feeFixed         Decimal       @default(0.0) @db.Decimal(10, 2)
  feePercentage    Decimal       @default(0.0) @db.Decimal(10, 2)
  
  organizerId      Int
  organizer        OrganizerProfile @relation(fields: [organizerId], references: [id])
  
  categoryId       Int
  category         Category      @relation(fields: [categoryId], references: [id])
  
  cityId           Int
  city             City          @relation(fields: [cityId], references: [id])
  
  tiers            TicketTier[]
  tickets          Ticket[]
  transactions     FinancialTransaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model TicketTier {
  id          Int      @id @default(autoincrement())
  name        String   // Regular, VIP, etc.
  price       Decimal  @db.Decimal(10, 2)
  capacity    Int
  eventId     Int
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets     Ticket[]
}

model Ticket {
  id           String       @id @default(uuid())
  qrPayload    String       @unique
  status       TicketStatus @default(VALID)
  
  userId       Int
  user         User         @relation(fields: [userId], references: [id])
  
  eventId      Int
  event        Event        @relation(fields: [eventId], references: [id])
  
  tierId       Int
  tier         TicketTier   @relation(fields: [tierId], references: [id])
  
  seatNumber   String?      // For SEAT_MAP events
  
  purchaseId   Int?
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id])

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Purchase {
  id             Int           @id @default(autoincrement())
  status         PaymentStatus @default(PENDING)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paymentRef     String        @unique // Our internal unique ref
  externalRef    String?       @unique // Provider's ref (Chapa, TeleBirr, etc)
  paymentMethod  String        // e.g., "CHAPA", "TELEBIRR", "CBE_BIRR", "AMOLE"
  failureReason  String?
  
  userId         Int
  user           User          @relation(fields: [userId], references: [id])
  
  metadata       Json?         // To store eventId, tierId, quantity, seatNumbers
  
  tickets        Ticket[]
  transactions   FinancialTransaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model OrganizerWallet {
  id               Int             @id @default(autoincrement())
  organizerId      Int             @unique
  organizer        OrganizerProfile @relation(fields: [organizerId], references: [id])
  
  pendingBalance   Decimal         @default(0.0) @db.Decimal(12, 2)
  availableBalance Decimal         @default(0.0) @db.Decimal(12, 2)
  totalWithdrawn   Decimal         @default(0.0) @db.Decimal(12, 2)
  
  ledgerEntries    WalletLedger[]
  payouts          PayoutBatch[]
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model WalletLedger {
  id               Int             @id @default(autoincrement())
  walletId         Int
  wallet           OrganizerWallet @relation(fields: [walletId], references: [id])
  
  amount           Decimal         @db.Decimal(12, 2)
  type             TransactionType
  description      String?
  referenceId      String          // ID of related entity (Purchase, PayoutBatch, etc)
  
  balanceBefore    Decimal         @db.Decimal(12, 2)
  balanceAfter     Decimal         @db.Decimal(12, 2)
  
  createdAt        DateTime        @default(now())
}

model FinancialTransaction {
  id               Int             @id @default(autoincrement())
  status           FinancialStatus @default(INITIATED)
  type             TransactionType
  
  amount           Decimal         @db.Decimal(10, 2)
  feeAmount        Decimal         @default(0.0) @db.Decimal(10, 2)
  netAmount        Decimal         @db.Decimal(10, 2) // amount - feeAmount
  
  purchaseId       Int?
  purchase         Purchase?       @relation(fields: [purchaseId], references: [id])
  
  eventId          Int?
  event            Event?          @relation(fields: [eventId], references: [id])
  
  payoutBatchId    Int?
  payoutBatch      PayoutBatch?    @relation(fields: [payoutBatchId], references: [id])
  
  metadata         Json?
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PayoutBatch {
  id               Int             @id @default(autoincrement())
  status           FinancialStatus @default(INITIATED)
  
  amount           Decimal         @db.Decimal(12, 2)
  method           PayoutMethod
  payoutDetails    String          // Bank/Mobile details used for this payout
  
  walletId         Int
  wallet           OrganizerWallet @relation(fields: [walletId], references: [id])
  
  transactions     FinancialTransaction[]
  
  processedAt      DateTime?
  adminId          Int?            // The admin who approved/processed it
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PlatformFeeConfig {
  id               Int      @id @default(autoincrement())
  name             String   // e.g., "Default Global Fee"
  feeType          String   @default("PERCENTAGE") // PERCENTAGE, FIXED, HYBRID
  feeFixed         Decimal  @default(0.0) @db.Decimal(10, 2)
  feePercentage    Decimal  @default(0.0) @db.Decimal(10, 2)
  isDefault        Boolean  @default(false)
  isActive         Boolean  @default(true)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ScanLog {
  id            Int      @id @default(autoincrement())
  ticketId      String
  eventId       Int
  gateId        String?
  deviceId      String?
  mode          String   // "ONLINE" | "OFFLINE"
  status        String   // "SUCCESS" | "REJECTED"
  reason        String?
  timestamp     DateTime @default(now())
  deviceTime    DateTime? // Original time from device for offline sync
  
  metadata      Json?    // Any extra context (e.g. error details)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
