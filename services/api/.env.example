# =============================================================================
# ET-TICKET PLATFORM — SUPABASE ENVIRONMENT TEMPLATE
# =============================================================================
# 1. Copy this file to .env
# 2. Fill in your real values (marked with YOUR_...)
# 3. Run: node scripts/supabase-orchestrator.js
# =============================================================================

# ── SUPABASE DATABASE ────────────────────────────────────────────────────────
# Get these from Supabase Dashboard → Project Settings → Database
# Pooled URL (port 6543 is auto-transaction mode — the code handles it)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?pgbouncer=true"
# Direct URL (non-pooled, for Prisma migrations and long-running queries)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-YOUR_REGION.supabase.com:5432/postgres"

# ── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET="generate-a-strong-random-secret-at-least-32-chars"

# ── REDIS (Required: OTP rate-limiting, distributed locks, session cache) ───
# Get a free instance at https://upstash.com
REDIS_URL="rediss://YOUR_UPSTASH_ENDPOINT:6379"

# ── PAYMENT PROVIDERS (Ethiopian Gateways) ──────────────────────────────────
# Chapa — https://dashboard.chapa.co
CHAPA_SECRET_KEY="CHASECK_TEST-your-chapa-test-key"

# Telebirr — credentials from your Telebirr merchant registration
TELEBIRR_MERCHANT_APP_ID="your-merchant-app-id"
TELEBIRR_FABRIC_APP_ID="your-fabric-app-id"
TELEBIRR_SHORT_CODE="402666"
TELEBIRR_APP_SECRET="your-telebirr-app-secret"
TELEBIRR_PRIVATE_KEY="your-multiline-pem-private-key"
TELEBIRR_API_URL="https://196.188.120.3:38443/apiaccess/payment/gateway"

# ── FILE STORAGE ────────────────────────────────────────────────────────────
STORAGE_TYPE="DISK"  # "DISK" for local, "S3" for AWS S3
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-aws-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret"
# S3_BUCKET_NAME="your-s3-bucket"

# ── NOTIFICATIONS ───────────────────────────────────────────────────────────
# SMS via Twilio
# TWILIO_ACCOUNT_SID="your-twilio-sid"
# TWILIO_AUTH_TOKEN="your-twilio-token"
# TWILIO_PHONE_NUMBER="+1234567890"

# Email via SendGrid
# SENDGRID_API_KEY="your-sendgrid-key"

# Push via Firebase
# FIREBASE_PROJECT_ID="your-firebase-project"
# FIREBASE_PRIVATE_KEY="your-firebase-private-key"
# FIREBASE_CLIENT_EMAIL="your-firebase-client-email"

# ── DEPLOYMENT ──────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT="4001"
API_URL="https://your-vercel-app.vercel.app"
