{
    "version": 2,
    "builds": [
        {
            "src": "src/server.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/server.ts"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/reminders",
            "schedule": "0 12 * * *"
        },
        {
            "path": "/api/cron/reconcile",
            "schedule": "0 0 * * *"
        }
    ]
}