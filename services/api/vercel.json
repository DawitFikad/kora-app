{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/version",
            "destination": "/api/version"
        },
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/reminders",
            "schedule": "0 12 * * *"
        },
        {
            "path": "/api/cron/reconcile",
            "schedule": "0 0 * * *"
        }
    ]
}